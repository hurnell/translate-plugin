<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.hurnell.translationnavigation</id>
    <name>Translation Navigation</name>
    <vendor>Hurnell</vendor>

    <description><![CDATA[
        <p>Navigate AngularJS translation keys to their JSON definitions.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.xml</depends>
    <depends>com.intellij.modules.json</depends>
    <extensions defaultExtensionNs="com.intellij">
        <psi.referenceContributor
                language="XML"
                implementation="com.hurnell.translationnavigation.TranslationReferenceContributor"/>
        <gotoDeclarationHandler implementation="com.hurnell.translationnavigation.TranslationGotoDeclarationHandler" />
        <projectService serviceImplementation="com.hurnell.translationnavigation.TranslationSettings"/>

        <!-- Settings panel interface (appears under Settings/Preferences > Tools) -->
        <projectConfigurable
                parentId="tools"
                instance="com.hurnell.translationnavigation.TranslationSettingsConfigurable"
                id="com.hurnell.translationnavigation.TranslationSettingsConfigurable"
                displayName="Translation Navigation" />
    </extensions>

</idea-plugin>